Bootstrap: docker
From: nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04 # ベースとなるnvidia/cudaイメージ

%files
    # 手元の設定ファイルをコンテナ内にコピー
    pyproject.toml /workspace/pyproject.toml
    uv.lock /workspace/uv.lock
    .python-version /workspace/.python-version

%post
    # uvをインストール
    apt-get update && apt-get install -y curl
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # 作業ディレクトリに移動してインストールを実行
    mkdir -p /workspace
    cd /workspace
    # --frozen をつけることで、lockファイルを変更せずに厳密にインストール
    uv sync --frozen --no-dev

%environment
    # インストールされた仮想環境にパスを通す
    export PATH="/workspace/.venv/bin:$PATH"
